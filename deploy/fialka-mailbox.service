[Unit]
Description=Fialka Mailbox — self-hosted message relay
After=network.target tor.service
Wants=tor.service

[Service]
Type=simple
User=fialka
Group=fialka
ExecStart=/usr/local/bin/fialka start
ExecStop=/usr/local/bin/fialka stop
Restart=on-failure
RestartSec=5s

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/fialka-mailbox

[Install]
WantedBy=multi-user.target
